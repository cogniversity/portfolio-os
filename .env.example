# Database
DATABASE_URL="postgresql://portfolio:portfolio@localhost:5432/portfolio_os?schema=public"

# NextAuth
AUTH_SECRET="change-me-to-a-long-random-string"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# Google OAuth (optional - leave blank to disable Google sign-in)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# OpenAI (optional - required to enable AI assist features: /ai/plan, Suggest children, Improve description)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
# Leave blank for api.openai.com; set for Azure or OpenAI-compatible endpoints
OPENAI_BASE_URL=""
